// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  createdAt DateTime @default(now())
}

// 게시판 회원
model User {
  id        Int         @id @default(autoincrement())
  affil     String      // 소속 (예: 동해삼육고)
  studentId String      @unique // 학번
  name      String      // 성명
  password  String      // scrypt 해시
  posts     BoardPost[]
  createdAt DateTime    @default(now())
}

// 메일 보내기 기록 (버튼 클릭 시 남는 로그)
model SentMail {
  id         Int      @id @default(autoincrement())
  senderName String? // 로그인 시 이름, 아니면 비움
  toEmail    String   // 받는 사람
  subject    String   // 제목
  method     String   // "gmail" 또는 "outlook"
  createdAt  DateTime @default(now())
}

// 실시간 채팅 메시지
model ChatMessage {
  id        Int      @id @default(autoincrement())
  studentId String   // 작성자 학번
  name      String   // 작성자 이름
  content   String   // 메시지 내용
  createdAt DateTime @default(now())
}

// 학습 소감 게시글 (작성자 본인만 열람 가능)
model BoardPost {
  id        Int      @id @default(autoincrement())
  subject   String   // 과목
  title     String
  content   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
